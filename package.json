{
  "name": "neue-docs",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "prepare": "lefthook install",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "npm run test:unit && npm run test:component && npm run test:integration && npm run test:smoke && npm run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:e2e": "playwright test",
    "knip": "DATABASE_URL=postgresql://localhost/dummy npx knip"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "jsdom": "^26.1.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2",
    "ultracite": "^7.0.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3"
}
