{
  "name": "blodemd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "prepare": "test -d .git && lefthook install || true",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "build:test-deps": "turbo build --filter=@repo/common --filter=@repo/contracts --filter=@repo/db",
    "build:docs-test-deps": "turbo build --filter=@repo/common --filter=@repo/contracts --filter=@repo/models --filter=@repo/prebuild --filter=@repo/previewing --filter=@repo/validation",
    "test": "npm run test:unit && npm run test:component && npm run test:integration && npm run test:smoke && npm run test:e2e",
    "pretest:unit": "npm run build:test-deps",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "pretest:integration": "npm run build:test-deps",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "pretest:smoke": "npm run build:test-deps",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "pretest:e2e": "npm run build:docs-test-deps",
    "test:e2e": "playwright test",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:push": "npm run db:local:push --workspace=packages/db",
    "db:seed": "npm run db:local:seed --workspace=packages/db",
    "knip": "DATABASE_URL=postgresql://localhost/dummy npx knip"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.8.0",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.20",
    "typescript": "6.0.2",
    "ultracite": "^7.0.5",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3"
}
