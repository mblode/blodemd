{
  "name": "blodemd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "prepare": "test -d .git && lefthook install || true",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "build:packages": "turbo build --filter=./packages/*",
    "pretest": "npm run build:packages",
    "test": "vitest run && npm run test:e2e",
    "pretest:unit": "npm run build:packages",
    "test:unit": "vitest run --project unit",
    "pretest:component": "npm run build:packages",
    "test:component": "vitest run --project component --passWithNoTests",
    "pretest:integration": "npm run build:packages",
    "test:integration": "vitest run --project integration",
    "pretest:smoke": "npm run build:packages",
    "test:smoke": "vitest run --project smoke",
    "pretest:e2e": "turbo build --filter=web --filter=docs --filter=dashboard",
    "test:e2e": "playwright test",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:push": "npm run db:local:push --workspace=packages/db",
    "db:seed": "npm run db:local:seed --workspace=packages/db",
    "knip": "DATABASE_URL=postgresql://localhost/dummy npx knip"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.4",
    "typescript": "7.0.2",
    "ultracite": "7.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "rolldown-plugin-dts": {
      "typescript": "$typescript"
    },
    "tsdown": {
      "typescript": "$typescript"
    }
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "npm@12.0.1"
}
