{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "ignoreBinaries": ["knip"],
      "ignoreDependencies": ["ultracite"]
    },
    "apps/*": {},
    "apps/api": {
      "ignoreBinaries": ["portless"],
      "ignoreDependencies": ["tsx"]
    },
    "apps/docs": {
      "ignoreBinaries": ["portless"]
    },
    "packages/*": {},
    "packages/db": {
      "entry": ["seed.ts"]
    },
    "apps/cli": {
      "entry": ["src/bin.ts"]
    },
    "packages/typescript-config": {
      "ignoreDependencies": ["next"]
    }
  }
}
