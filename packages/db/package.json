{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "db:pull": "NODE_PATH=./node_modules drizzle-kit pull --config=drizzle.config.ts",
    "db:push": "NODE_PATH=./node_modules drizzle-kit push --config=drizzle.config.ts",
    "db:push:init": "NODE_PATH=./node_modules drizzle-kit push --config=drizzle.config.ts --init",
    "db:local:push": "node ./scripts/local-db.mjs push --force",
    "db:local:push:init": "node ./scripts/local-db.mjs push --init --force",
    "db:local:url": "node ./scripts/local-db.mjs print-url"
  },
  "dependencies": {
    "@repo/contracts": "*",
    "drizzle-orm": "^1.0.0-beta.19",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.19.15",
    "drizzle-kit": "^1.0.0-beta.19",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "6.0.2",
    "ultracite": "^7.3.2"
  }
}
