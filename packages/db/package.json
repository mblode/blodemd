{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "db:generate": "NODE_PATH=./node_modules drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "node ./scripts/migrate.mjs && node ./scripts/apply-auth-user-sync.mjs",
    "db:check": "NODE_PATH=./node_modules drizzle-kit check --config=drizzle.config.ts",
    "db:studio": "NODE_PATH=./node_modules drizzle-kit studio --config=drizzle.config.ts",
    "db:pull": "NODE_PATH=./node_modules drizzle-kit pull --config=drizzle.config.ts",
    "db:push": "NODE_PATH=./node_modules drizzle-kit push --config=drizzle.config.ts && node ./scripts/apply-auth-user-sync.mjs",
    "db:sync-auth-users": "node ./scripts/apply-auth-user-sync.mjs",
    "db:local:migrate": "node ./scripts/local-db.mjs migrate",
    "db:local:seed": "node ./scripts/local-db.mjs seed",
    "db:local:url": "node ./scripts/local-db.mjs print-url"
  },
  "dependencies": {
    "@repo/contracts": "*",
    "drizzle-orm": "^1.0.0-beta.19",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^1.0.0-beta.19",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "6.0.3",
    "ultracite": "7.9.3"
  }
}
