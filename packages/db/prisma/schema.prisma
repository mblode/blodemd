generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DomainStatus {
  ValidConfiguration  @map("valid_configuration")
  PendingVerification @map("pending_verification")
  InvalidConfiguration @map("invalid_configuration")

  @@map("domain_status")
}

enum DeploymentStatus {
  Queued     @map("queued")
  Building   @map("building")
  Successful @map("successful")
  Failed     @map("failed")

  @@map("deployment_status")
}

enum DeploymentEnvironment {
  Production @map("production")
  Preview    @map("preview")

  @@map("deployment_environment")
}

enum ActivityStatus {
  Queued     @map("queued")
  Building   @map("building")
  Successful @map("successful")
  Failed     @map("failed")

  @@map("activity_status")
}

enum MemberRole {
  Owner  @map("owner")
  Admin  @map("admin")
  Member @map("member")

  @@map("member_role")
}

enum MemberStatus {
  Active    @map("active")
  Invited   @map("invited")
  Suspended @map("suspended")

  @@map("member_status")
}

enum GitProvider {
  Github @map("github")

  @@map("git_provider")
}

model Workspace {
  id         String            @id @default(uuid()) @db.Uuid
  slug       String            @unique
  name       String
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  projects   Project[]
  members    WorkspaceMember[]
  apiKeys    ApiKey[]

  @@map("workspaces")
}

model Profile {
  id        String   @id @db.Uuid
  email     String
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model WorkspaceMember {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @db.Uuid @map("workspace_id")
  email       String
  role        MemberRole   @default(Member)
  status      MemberStatus @default(Invited)
  joinedAt    DateTime?    @map("joined_at")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_members")
}

model Project {
  id             String          @id @default(uuid()) @db.Uuid
  workspaceId    String          @db.Uuid @map("workspace_id")
  slug           String
  name           String
  deploymentName String          @map("deployment_name")
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domains        Domain[]
  deployments    Deployment[]
  activity       Activity[]
  gitConnections GitConnection[]

  @@unique([workspaceId, slug])
  @@map("projects")
}

model Domain {
  id         String       @id @default(uuid()) @db.Uuid
  projectId  String       @db.Uuid @map("project_id")
  hostname   String       @unique
  pathPrefix String?      @map("path_prefix")
  status     DomainStatus @default(PendingVerification)
  createdAt  DateTime     @default(now()) @map("created_at")
  verifiedAt DateTime?    @map("verified_at")
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("domains")
}

model Deployment {
  id            String               @id @default(uuid()) @db.Uuid
  projectId     String               @db.Uuid @map("project_id")
  environment   DeploymentEnvironment @default(Production)
  status        DeploymentStatus     @default(Queued)
  branch        String
  commitMessage String?              @map("commit_message")
  changes       String?
  previewUrl    String?              @map("preview_url")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("deployments")
}

model Activity {
  id             String         @id @default(uuid()) @db.Uuid
  projectId      String         @db.Uuid @map("project_id")
  summary        String
  status         ActivityStatus @default(Queued)
  changes        String?
  actorName      String         @map("actor_name")
  actorAvatarUrl String?        @map("actor_avatar_url")
  occurredAt     DateTime       @default(now()) @map("occurred_at")
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("activity")
}

model GitConnection {
  id           String      @id @default(uuid()) @db.Uuid
  projectId    String      @db.Uuid @map("project_id")
  provider     GitProvider @default(Github)
  organization String
  repository   String
  branch       String
  isMonorepo   Boolean     @default(false) @map("is_monorepo")
  docsPath     String?     @map("docs_path")
  appInstalled Boolean     @default(false) @map("app_installed")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("git_connections")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid @map("workspace_id")
  name       String
  prefix     String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}
