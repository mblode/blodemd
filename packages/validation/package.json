{
  "name": "@repo/validation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check-types": "tsc --noEmit",
    "generate:docs-schema": "node ./scripts/generate-blodemd-docs-schema.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt ."
  },
  "dependencies": {
    "@repo/models": "*"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.19.15",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "6.0.2",
    "ultracite": "^7.3.2"
  }
}
