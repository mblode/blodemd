{
  "name": "@repo/mdx-compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt ."
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@shikijs/rehype": "^4.3.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  }
}
