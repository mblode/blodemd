{
  "$schema": "https://mintlify.com/docs.json",
  "colors": {
    "primary": "#0FB59F",
    "light": "#CFF6EE",
    "dark": "#0C3A33"
  },
  "name": "Atlas Platform Docs",
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Concepts",
        "pages": ["concepts"]
      },
      {
        "group": "Domains",
        "pages": [
          "domains/wildcard-domains",
          "domains/custom-domains",
          "domains/verification",
          "domains/custom-subpaths"
        ]
      },
      {
        "group": "Previews",
        "pages": ["previews/multi-tenant-preview-urls"]
      },
      {
        "group": "Platform Elements",
        "pages": [
          "platform-elements/actions/add-custom-domain",
          "platform-elements/actions/deploy-files",
          "platform-elements/blocks/custom-domain",
          "platform-elements/blocks/dns-table"
        ]
      },
      {
        "group": "Templates",
        "pages": ["templates/multi-tenant-template"]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/domain-api",
          "reference/limits",
          "reference/troubleshooting"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api/overview",
          "GET /projects",
          "POST /projects",
          "GET /projects/{projectId}",
          "PATCH /projects/{projectId}",
          "GET /deployments"
        ]
      }
    ]
  },
  "theme": "mint",
  "description": "Build a Mintlify-style documentation platform on Vercel.",
  "logo": {
    "light": "/logos/atlas-mark-dark.svg",
    "dark": "/logos/atlas-mark-light.svg"
  },
  "fonts": {
    "body": {
      "family": "Space Grotesk"
    },
    "heading": {
      "family": "Fraunces"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "https://dashboard.atlas.example",
        "label": "Dashboard"
      },
      {
        "href": "https://status.atlas.example",
        "label": "Status"
      }
    ]
  },
  "api": {
    "openapi": {
      "source": "openapi.yaml",
      "directory": "api"
    },
    "playground": {
      "proxy": true
    }
  }
}
