{
  "name": "blodemd",
  "version": "0.2.0",
  "description": "Blode.md CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/mblode/blodemd"
  },
  "bin": {
    "blodemd": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "node scripts/prepare-package.mjs",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "test:unit": "sh -c 'cd ../.. && vitest run --config vitest.config.ts --project unit apps/cli/src'"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "open": "^10.2.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/common": "*",
    "@repo/contracts": "*",
    "@repo/models": "*",
    "@repo/previewing": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^24.12.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.5",
    "ultracite": "^7.3.2"
  },
  "engines": {
    "node": "24.x"
  }
}
