{
  "name": "blode-docs",
  "version": "0.0.2",
  "bin": {
    "blode-docs": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown src/bin.ts --format esm --platform node --no-dts --out-dir dist",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt ."
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.5",
    "ultracite": "^7.3.2"
  }
}
