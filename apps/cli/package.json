{
  "name": "blodemd",
  "version": "0.0.8",
  "description": "Blode.md CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/mblode/blodemd"
  },
  "bin": {
    "blodemd": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "dev-server",
    "docs",
    "packages",
    "scripts/prepare-package.mjs"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "node scripts/prepare-package.mjs",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "test:unit": "vitest run --root ../.. --config vitest.unit.config.ts apps/cli/src"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clack/prompts": "^1.0.0",
    "@mdx-js/mdx": "^3.1.1",
    "@repo/common": "*",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "blode-icons-react": "^0.3.10",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.0",
    "geist": "^1.7.0",
    "next": "16.2.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "open": "^10.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shadcn": "^4.1.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/previewing": "*",
    "@repo/typescript-config": "*",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.5",
    "ultracite": "^7.3.2"
  },
  "engines": {
    "node": ">=20.17.0"
  }
}
