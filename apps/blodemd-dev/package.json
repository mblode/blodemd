{
  "name": "blodemd-dev",
  "version": "0.2.0",
  "description": "Blode.md dev server runtime (companion package for blodemd)",
  "repository": {
    "type": "git",
    "url": "https://github.com/mblode/blodemd"
  },
  "bin": {
    "blodemd-dev": "./dist/dev.mjs"
  },
  "files": [
    "dist",
    "dev-server",
    "docs",
    "packages",
    "scripts/*.mjs"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "prepare": "node scripts/prepare-package.mjs",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@mdx-js/mdx": "^3.1.1",
    "@shikijs/rehype": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "blode-icons-react": "^0.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "geist": "^1.7.2",
    "merge-refs": "^2.0.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "open": "^11.0.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.5",
    "ultracite": "7.9.3"
  },
  "engines": {
    "node": "24.x"
  }
}
