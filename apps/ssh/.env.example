SSH_PORT=2222
DOCS_APP_URL=https://blode.md
PLATFORM_ROOT_DOMAIN=blode.md

# Generate a persistent host key so users don't get "host key changed" warnings.
# Run once and save the output — keep the same value across deploys:
#
#   openssl genpkey -algorithm ed25519 | base64 -w0
#
# On Fly.io use secrets instead of .env:
#   fly secrets set SSH_HOST_KEY=$(openssl genpkey -algorithm ed25519 | base64 -w0)
SSH_HOST_KEY=
