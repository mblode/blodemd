{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Keep @repo/* on package-root resolution. Pointing at packages/*/src/index.ts
    // bypasses package exports and breaks Turbopack module resolution.
    "paths": {
      "@/*": ["../docs/*"],
      "@dev/*": ["./*"]
    },
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
