{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run sh -c 'set -a && . .env && set +a && tsx watch src/index.ts'",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "backfill:edge-config": "sh -c 'set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; tsx scripts/backfill-edge-config.ts'",
    "test:unit": "sh -c 'cd ../.. && npm run build:test-deps && vitest run --config vitest.unit.config.ts apps/api/src'",
    "test:integration": "sh -c 'cd ../.. && npm run build:test-deps && vitest run --config vitest.integration.config.ts apps/api/src'",
    "test:smoke": "sh -c 'cd ../.. && npm run build:test-deps && vitest run --config vitest.smoke.config.ts apps/api/src'",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/rest": "^21.1.1",
    "@repo/common": "*",
    "@repo/contracts": "*",
    "@repo/db": "*",
    "@repo/mdx-compiler": "*",
    "@repo/models": "*",
    "@repo/prebuild": "*",
    "@repo/previewing": "^0.0.0",
    "@vercel/blob": "^2.3.1",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^24.12.2",
    "drizzle-orm": "^1.0.0-beta.19",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.2",
    "typescript": "6.0.2",
    "ultracite": "^7.3.2"
  },
  "engines": {
    "node": "24.x"
  }
}
