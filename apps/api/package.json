{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run sh -c 'set -a && . .env && set +a && tsx watch src/index.ts'",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@repo/common": "*",
    "@repo/contracts": "*",
    "@repo/db": "*",
    "@repo/previewing": "^0.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "@vercel/blob": "^2.3.1",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.19.15",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.2",
    "typescript": "6.0.2",
    "ultracite": "^7.3.2"
  }
}
